tErrorFieldFocus, 250);\n        });\n    }\n})();\n</script>\n\n<!-- 权限错误模态窗口 -->\n<div class="modal fade" id="permissionErrorModal" tabindex="-1" aria-labelledby="permissionErrorModalLabel" aria-hidden="true">\n    <div class="modal-dialog modal-dialog-centered">\n        <div class="modal-content border-0 shadow">\n            <div class="modal-header bg-danger text-white py-2">\n                <h5 class="modal-title" id="permissionErrorModalLabel">\n                    <i class="mdi mdi-alert-circle-outline me-1"></i>权限错误\n                </h5>\n                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>\n            </div>\n            <div class="modal-body p-4">\n                <div class="d-flex align-items-center">\n                    <span class="text-danger me-3" style="font-size: 2.2rem;">\n                        <i class="mdi mdi-shield-alert-outline"></i>\n                    </span>\n                    <p class="mb-0 text-secondary" id="permissionErrorModalMessage" style="font-size: 1rem; line-height: 1.5;"></p>\n                </div>\n            </div>\n            <div class="modal-footer bg-light border-top-0 py-2">\n                <button type="button" class="btn btn-secondary btn-sm px-4" data-bs-dismiss="modal">确定</button>\n            </div>\n        </div>\n    </div>\n</div>\n\n{% include \'netbox_otnfaults/inc/flatpickr_zh.html\' %}\n{% include \'netbox_otnfaults/inc/duration_calc.html\' %}\n{% endblock %}\n'

