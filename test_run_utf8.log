      const faultLineManagerId = "{{ form.instance.line_manager.id|default:\'\' }}";\n        const faultOpsManagerIds = [{% for u in form.instance.operations_manager.all %}"{{ u.id }}",{% endfor %}];\n\n        const currentUser = "{{ request.user.first_name }}{{ request.user.last_name }}" || "{{ request.user.username }}";\n        const ongoingImpactCountAttr = \'data-ongoing-impact-count\';\n        const ongoingImpactWarningAttr = \'data-ongoing-impact-warning\';\n        \n        function setupReviewerSync(checkId, nameId, timeId) {\n            const checkEl = document.getElementById(checkId);\n            const nameEl = document.getElementById(nameId);\n            const timeEl = document.getElementById(timeId);\n            \n            if (checkEl && nameEl && timeEl) {\n                // 在 click 阶段拦截权限\n                checkEl.addEventListener(\'click\', function(e) {\n                    if (!isSuperUser) {\n                        if (checkId === \'id_manager_reviewed\') {\n                            if (currentUserId !== faultLineManagerId) {\n                                e.preventDefault();\n                                showPermissionErrorModal(\'只有当前故障的线路主管才可以进行复核操作。\');\n                                return;\n                            }\n                        } else if (checkId === \'id_noc_reviewed\') {\n                            if (!faultOpsManagerIds.includes(currentUserId)) {\n                                e.preventDefault();\n                                showPermissionErrorModal(\'只有当前故障的运维主管才可以进行复核操作。\');\n                                return;\n                            }\n                        }\n                    }\n                });\n\n                checkEl.addEventListener(\'change\', function() {\n                    if (this.checked) {\n                        const ongoingImpactCount = Number(checkEl.getAttribute(ongoingImpactCountAttr) || \'0\');\n                        if (ongoingImpactCount > 0) {\n                            alert(checkEl.getAttribute(ongoingImpactWarningAttr) || \'该物理故障下仍有业务故障处于持续状态，请先检查业务恢复时间。\');\n                        }\n                        nameEl.value = currentUser;\n                        const now = new Date();\n                        const f = (n) => n.toString().padStart(2, \'0\');\n                        \n                        if (timeEl._flatpickr) {\n                            timeEl._flatpickr.setDate(now);\n                        } else {\n                            timeEl.value = `${now.getFullYear()}-${f(now.getMonth()+1)}-${f(now.getDate())} ${f(now.getHours())}:${f(now.getMinutes())}:${f(now.getSeconds())}`;\n                        }\n                    } else {\n                        nameEl.value = \'\';\n                        if (timeEl._flatpickr) {\n                            timeEl._flatpickr.clear();\n                        } else {\n                            timeEl.value = \'\';\n                        }\n                    }\n                });\n            }\n        }\n        \n        setupReviewerSync(\'id_manager_reviewed\', \'id_manager_reviewer\', \'id_manager_review_time\');\n        setupReviewerSync(\'id_noc_reviewed\', \'id_noc_reviewer\', \'id_noc_review_time\');\n\n        // 检测后端返回的拦截状态并自动弹窗提示\n        const showBackendError = {% if show_permission_denied_modal %}true{% else %}false{% endif %};\n        const backendErrorMessage = "{{ permission_denied_message|escapejs }}";\n        if (showBackendError && backendErrorMessage) {\n            showPermissionErrorModal(backendErrorMessage);\n        }\n    }\n\n    function initErrorFieldFocus() {\n        const firstError = document.querySelector(\'.is-invalid, .invalid-feedback, .text-danger\');\n        if (!firstError) return;\n\n        const errorRow = firstError.closest(\'.row\') || firstError.closest(\'.mb-3\') || firstError;\n        const focusTarget = errorRow.querySelector(\'input:not([type="hidden"]), select, textarea, button\') ||\n            firstError.closest(\'.form-group\')?.querySelector(\'input:not([type="hidden"]), select, textarea, button\');\n\n        errorRow.scrollIntoView({ behavior: \'smooth\', block: \'center\' });\n        if (focusTarget && typeof focusTarget.focus === \'function\') {\n            focusTarget.focus({ preventScroll: true });\n        }\n    }\n\n    function initSuspendedStatusSync() {\n        const statusSelect = document.querySelector(\'select[name="fault_status"]\');\n        const suspendedInput = document.querySelector(\'input[name="is_suspended"]\');\n        if (!statusSelect || !suspendedInput) return;\n\n        const syncSuspendedFlag = (value) => {\n            if (value === SUSPENDED_STATUS) {\n                suspendedInput.checked = true;\n            }\n        };\n\n        if (statusSelect.tomselect) {\n            statusSelect.tomselect.on(\'change\', syncSuspendedFlag);\n            syncSuspendedFlag(statusSelect.tomselect.getValue());\n        } else {\n            statusSelect.addEventListener(\'change\', function() {\n                syncSuspendedFlag(this.value);\n            });\n            syncSuspendedFlag(statusSelect.value);\n        }\n    }\n\n    // Z端快捷定位：根据A端站点自动查找有路径连通的站点，并提供快捷选择\n    function initPathShortcuts() {\n        const aSiteSelect = document.querySelector(\'select[name="interruption_location_a"]\');\n        const zSiteSelect = document.querySelector(\'select[name="interruption_location"]\');\n        \n        if (!aSiteSelect || !zSiteSelect) return;\n        \n        const aSiteTS = aSiteSelect.tomselect;\n        const zSiteTS = zSiteSelect.tomselect;\n        \n        if (!aSiteTS || !zSiteTS) {\n            setTimeout(initPathShortcuts, 100);\n            return;\n        }\n\n        // 创建快捷标签行容器\n        let shortcutsRow = document.getElementById(\'z-site-shortcuts-row\');\n        let shortcutsContainer = null;\n        if (!shortcutsRow) {\n            shortcutsRow = document.createElement(\'div\');\n            shortcutsRow.id = \'z-site-shortcuts-row\';\n            // 使用标准的 Bootstrap row 布局，并用 mb-3 保持与表单行距一致\n            shortcutsRow.className = \'row mb-3\';\n            \n            // 左侧留白 (匹配 label 的宽度)，右侧放置提示区域\n            shortcutsRow.innerHTML = `\n                <div class="col-sm-3"></div>\n                <div class="col-sm-9" id="z-site-shortcuts-container"></div>\n            `;\n            \n            // 将新行插入到 Z 端站点输入框这一行的正下方\n            let zRow = zSiteSelect.closest(\'.row\');\n            if (zRow && zRow.parentNode) {\n                zRow.parentNode.insertBefore(shortcutsRow, zRow.nextSibling);\n            } else {\n                zSiteSelect.parentNode.appendChild(shortcutsRow);\n            }\n        }\n        shortcutsContainer = document.getElementById(\'z-site-shortcuts-container\');\n\n        function fetchAndRenderShortcuts(siteAId) {\n            shortcutsContainer.innerHTML = \'\'; // 清空提示\n            if (!siteAId) return;\n\n            // 提示正在加载\n            shortcutsContainer.innerHTML = \'<span class="text-muted small"><i class="mdi mdi-loading mdi-spin"></i> 正在查找光缆路径连通站点...</span>\';\n\n            fetch(`/api/plugins/otnfaults/paths/?site=${siteAId}`, {\n                headers: {\n                    \'Accept\': \'application/json\',\n                    \'X-Requested-With\': \'XMLHttpRequest\'\n                },\n                credentials: \'same-origin\'\n            })\n            .then(res => res.json())\n            .then(data => {\n                if (!data.results || data.results.length === 0) {\n                    shortcutsContainer.innerHTML = \'<span class="text-muted small">该站点未查询到连通的光缆路径。您仍可自行搜索并选择Z端站点。</span>\';\n                    return;\n                }\n\n                // 提取连接的Z端站点并去重\n                const connectedSites = {};\n                data.results.forEach(path => {\n                    let connectedSite = null;\n                    if (path.site_a && path.