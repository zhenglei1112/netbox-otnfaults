{% render_field form.noc_reviewed %}\n        {% render_field form.noc_reviewer %}\n        {% render_field form.noc_review_time %}\n    </div>\n</div>\n\n<div class="field-group my-5">\n    <div class="row mb-3">\n        <h2 class="col-9 offset-3 mb-0">其他信息</h2>\n    </div>\n    <div class="row">\n        {% render_field form.comments %}\n    </div>\n</div>\n\n<script>\n(function() {\n    \'use strict\';\n    \n    // 光缆相关故障类型\n    const FIBER_FAULT_CATEGORIES = [\'fiber_break\', \'fiber_degradation\', \'fiber_jitter\'];\n    // 供电故障类型\n    const POWER_FAULT_CATEGORY = \'power_fault\';\n    const POWER_RECTIFICATION_REASON = \'power_equipment_rectification\';\n    const SUSPENDED_STATUS = \'suspended\';\n\n    // 故障分类 -> 一级原因映射\n    const CATEGORY_TO_REASON_MAP = {\n        \'fiber_break\': [\'construction\', \'human_factor\', \'traffic_accident\', \n                        \'animal_damage\', \'natural_disaster\', \'fire\', \n                        \'unknown\', \'cable_rectification\'],\n        \'fiber_degradation\': [\'construction\', \'human_factor\', \'traffic_accident\', \n                              \'animal_damage\', \'natural_disaster\', \'fire\', \n                              \'unknown\', \'cable_rectification\'],\n        \'fiber_jitter\': [\'construction\', \'human_factor\', \'traffic_accident\', \n                         \'animal_damage\', \'natural_disaster\', \'fire\', \n                         \'unknown\', \'cable_rectification\'],\n        \'ac_fault\': [\'ac_refrigerant\', \'ac_mainunit\', \'ac_overload\', \n                     \'ac_outdoor_blocked\', \'ac_no_autostart\'],\n        \'device_fault\': [\'optical_module\', \'software_fault\', \'branch_card\', \n                         \'line_card\', \'main_control_card\', \'cross_card\', \n                         \'auxiliary_card\', \'power_card\', \'optical_layer_card\',\n                         \'chassis_fault\', \'misoperation_device\', \'device_relocation\', \n                         \'other_device\'],\n        \'power_fault\': [\'ac_fault_power\', \'power_equipment_fault\',\n                        \'misoperation_power\', \'natural_disaster_power\',\n                        \'unknown_power\', \'power_equipment_rectification\']\n    };\n    \n    // 一级原因 -> 二级原因映射\n    const REASON_TO_DETAIL_MAP = {\n        \'construction\': [\'municipal_construction\', \'greening_construction\', \n                         \'expansion_construction\', \'piling_construction\', \n                         \'ramp_construction\', \'station_renovation\', \'room_renovation\'],\n        \'human_factor\': [\'sabotage\', \'misoperation\'],\n        \'traffic_accident\': [\'vehicle_collision\', \'vehicle_fire\'],\n        \'animal_damage\': [\'bird_peck\', \'rodent_damage\', \'dog_bite\', \'ant_damage\'],\n        \'natural_disaster\': [\'flood\', \'earthquake\', \'storm\', \'mudslide\', \'road_collapse\'],\n        \'fire\': [\'burning_straw\', \'well_fire\', \'cigarette\'],\n        // 以下一级原因没有二级原因\n        \'unknown\': [],\n        \'cable_rectification\': [\'planned_reporting\', \'unplanned_reporting\'],\n        \'ac_refrigerant\': [],\n        \'ac_mainunit\': [],\n        \'ac_overload\': [],\n        \'ac_outdoor_blocked\': [],\n        \'ac_no_autostart\': [],\n        // 设备故障的一级原因（无二级原因）\n        \'optical_module\': [],\n        \'software_fault\': [],\n        \'branch_card\': [],\n        \'line_card\': [],\n        \'main_control_card\': [],\n        \'cross_card\': [],\n        \'auxiliary_card\': [],\n        \'power_card\': [],\n        \'optical_layer_card\': [],\n        \'chassis_fault\': [],\n        \'misoperation_device\': [],\n        \'device_relocation\': [],\n        \'other_device\': [],\n        // 供电故障的一级原因\n        \'ac_fault_power\': [\'room_power_test\', \'grid_power_maintenance\',\n                           \'breaker_trip\', \'ups_fault\', \'mains_power_outage\',\n                           \'natural_disaster_power_detail\', \'manual_misoperation\',\n                           \'other_power\'],\n        \'power_equipment_fault\': [\'switching_power_fault\', \'rectifier_module_fault\'],\n        \'misoperation_power\': [\'human_caused\'],\n        \'natural_disaster_power\': [\'power_flood\', \'power_rainstorm\', \'power_lightning\'],\n        \'unknown_power\': [],\n        \'power_equipment_rectification\': [\'power_relocation\', \'grid_power_maintenance\',\n                                          \'switching_power_rectification\',\n                                          \'battery_rectification\',\n                                          \'owner_unit_rectification\',\n                                          \'mains_power_outage\']\n    };\n    \n    // 保存原始选项\n    let allReasonOptions = [];\n    let allDetailOptions = [];\n\n    function findDirectFieldColumns(select) {\n        // Find the outer row container that holds all the fields\n        const containerRow = select.closest(\'.field-group\').querySelector(\'.row:not(.mb-3), .row:nth-of-type(2)\');\n        \n        // Find the direct child of this container that contains our select element\n        if (containerRow) {\n            const wrapper = Array.from(containerRow.children).find(child => child.contains(select));\n            if (wrapper) {\n                return [wrapper];\n            }\n        }\n        \n        // Fallback: just return the closest wrapper that usually contains a field\n        const fallbackWrapper = select.closest(\'.row.mb-3\') || select.closest(\'.mb-3\');\n        return fallbackWrapper ? [fallbackWrapper] : [];\n    }\n\n    function getContractFieldNodes() {\n        const handlingUnitSelect = document.querySelector(\'select[name="handling_unit"]\');\n        const contractSelect = document.querySelector(\'select[name="contract"]\');\n        if (!handlingUnitSelect || !contractSelect) return [];\n\n        return [\n            ...findDirectFieldColumns(handlingUnitSelect),\n            ...findDirectFieldColumns(contractSelect),\n        ];\n    }\n\n    function moveSharedContractFields(category) {\n        const targetAnchor = document.getElementById(\n            category === POWER_FAULT_CATEGORY\n                ? \'power-contract-fields-anchor\'\n                : \'fiber-contract-fields-anchor\'\n        );\n        const contractFieldNodes = getContractFieldNodes();\n\n        if (!targetAnchor || contractFieldNodes.length === 0 || !targetAnchor.parentNode) return;\n\n        contractFieldNodes.forEach(node => {\n            targetAnchor.parentNode.insertBefore(node, targetAnchor);\n        });\n    }\n    \n    function toggleFiberFields(category) {\n        const fiberInfoDiv = document.getElementById(\'fiber-supplementary-info\');\n        const powerInfoDiv = document.getElementById(\'power-supplementary-info\');\n        const powerFaultOnlyRows = document.querySelectorAll(\'[data-power-fault-only]\');\n        \n        if (!fiberInfoDiv || !powerInfoDiv) return;\n\n        moveSharedContractFields(category);\n        \n        // 控制光缆补充信息显示\n        if (FIBER_FAULT_CATEGORIES.includes(category)) {\n            fiberInfoDiv.style.display = \'block\';\n        } else {\n            fiberInfoDiv.style.display = \'none\';\n        }\n        \n        // 控制供电补充信息显示\n        if (category === POWER_FAULT_CATEGORY) {\n            powerInfoDiv.style.display = \'block\';\n            powerFaultOnlyRows.forEach(row => { row.style.display = \'\'; });\n        } else {\n            powerInfoDiv.style.display = \'none\';\n            powerFaultOnlyRows.forEach(row => { row.style.display = \'none\'; });\n        }\n    }\n\n    function toggleCutoverReportFields(category, reason) {\n        const cutoverRows = document.querySelectorAll(\'[data-cutover-report-only]\');\n        const shouldShow = category === POWER_FAULT_CATEGORY && reason === POWER_RECTIFICATION_REASON;\n        cutoverRows.forEach(row => { row.style.display = shouldShow ? \'\' : \'none\'; });\n    }\n    \n    let isCascadeUpdating = false;\n    \n    function initCascadeFilter() {\n        const categorySelect = document.querySelector(\'select[name="fault_category"]\');\n        const reasonSelect = document.querySelector(\'select[name="interruption_reason"]\');\n        const detailSelect = document.querySelector(\'select[name="interruption_reason_detail"]\');\n        \n        if (!categorySelect || !reasonSelect || !detailSelect) {\n            console.warn(\'[CascadeFilter] 表单元素未找到\');\n            return;\n        }\n        \n        // 获取 TomSelect 实例\n        const categoryTS = categorySelect.tomselect;\n        const reasonTS = reasonSelect.tomselect;\n        const detailTS = detailSelect.tomselect;\n        \n        if (!categoryTS || !reasonTS || !detailTS) {\n            console.warn(\'[CascadeFilter] TomSelect 实例未找到，延迟重试...\');\n            setTimeout(initCascadeFilter, 100);\n            return;\n        }\n        \n        // 保存所有原始选项\n        allReasonOptions = Array.from(reasonSelect.options).map(opt => ({\n            value: opt.value,\n            text: opt.text\n        }));\n        allDetailOptions = Array.from(detailSelect.options).map(opt => ({\n            value: opt.value,\n            text: opt.text\n        }));\n        \n        console.log(\'[CascadeFilter] 三级联动初始化完成\');\n        \n        // 监听故障分类变化\n        categoryTS.on(\'change\', function(value) {\n            if (isCascadeUpdating) return;\n            isCascadeUpdating = true;\n            console.log(\'[CascadeFilter] 故障分类变化:\', value);\n            updateReasonOptions(value, reasonTS);\n            // 清空二级原因\n            detailTS.clear(true);\n            detailTS.clearOptions();\n            detailTS.addOption({ value: \'\', text: \'---------\' });\n            detailTS.refreshOptions(false);\n            \n            // 切换光缆补充信息显隐\n            toggleFiberFields(value);\n            toggleCutoverReportFields(value, \'\');\n            isCascadeUpdating = false;\n        });\n        \n        // 监听一级原因变化\n        reasonTS.on(\'change\', function(value) {\n            if (isCascadeUpdating) return;\n            isCascadeUpdating = true;\n            console.log(\'[CascadeFilter] 一级原因变化:\', value);\n            updateDetailOptions(value, detailTS);\n            toggleCutoverReportFields(categoryTS.getValue(), value);\n            isCascadeUpdating = false;\n        });\n        \n        // 初始化：根据当前选中值筛选\n        isCascadeUpdating = true;\n        if (categorySelect.value) {\n            updateReasonOptions(categorySelect.value, reasonTS, true);\n            toggleFiberFields(categorySelect.value);\n        } else {\n            // 默认隐藏\n            toggleFiberFields(\'\');\n        }\n        toggleCutoverReportFields(categorySelect.value, reasonSelect.value);\n        \n        if (reasonSelect.value) {\n            updateDetailOptions(reasonSelect.value, detailTS, true);\n        }\n        \n        // 确保异步调用结束后再解开\n        setTimeout(() => { isCascadeUpdating = false; }, 50);\n    }\n    \n    function updateReasonOptions(category, reasonTS, preserveValue = false) {\n        const currentValue = preserveValue ? reasonTS.getValue() : \'\';\n        const allowedReasons = CATEGORY_TO_REASON_MAP[category] || [];\n        \n        // 清空选项 (silent = true以防止触发 change 事件)\n        reasonTS.clear(true);\n        reasonTS.clearOptions();\n        \n        // 添加空选项\n        reasonTS.addOption({ value: \'\', text: \'---------\' });\n        \n        // 筛选可用选项\n        allReasonOptions.forEach(opt => {\n            if (opt.value === \'\') return;\n            if (allowedReasons.includes(opt.value)) {\n                reasonTS.addOption({ value: opt.value, text: opt.text });\n            }\n        });\n        \n        reasonTS.refreshOptions(false);\n        \n        // 恢复之前的选中值（如果仍在可选范围内）\n        if (preserveValue && currentValue && Object.keys(reasonTS.options).includes(currentValue)) {\n            reasonTS.setValue(currentValue, true);\n        }\n    }\n    \n    function updateDetailOptions(reason, detailTS, preserveValue = false) {\n        const currentValue = preserveValue ? detailTS.getValue() : \'\';\n        const allowedDetails = REASON_TO_DETAIL_MAP[reason] || [];\n        \n        // 清空选项\n        detailTS.clear(true);\n        detailTS.clearOptions();\n        \n        // 添加空选项\n        detailTS.addOption({ value: \'\', text: \'---------\' });\n        \n        // 如果没有二级原因，直接返回\n        if (allowedDetails.length === 0) {\n            detailTS.refreshOptions(false);\n            return;\n        }\n        \n        // 筛选可用选项\n        allDetailOptions.forEach(opt => {\n            if (opt.value === \'\') return;\n            if (allowedDetails.includes(opt.value)) {\n                detailTS.addOption({ value: opt.value, text: opt.text });\n            }\n        });\n        \n        detailTS.refreshOptions(false);\n        \n        // 恢复之前的选中值（如果仍在可选范围内）\n        if (preserveValue && currentValue && Object.keys(detailTS.options).includes(currentValue)) {\n            detailTS.setValue(currentValue, true);\n        }\n    }\n    \n    // 初始化选点定位功能\n    function initMapPicker() {\n        const longitudeInput = document.getElementById(\'id_interruption_longitude\');\n        if (!longitudeInput) return;\n        \n        // 动态注入图标按钮到经度输入框右侧\n        const inputGroup = longitudeInput.closest(\'.input-group\');\n        let btnOpenMap;\n        \n        if (inputGroup) {\n            btnOpenMap = document.createElement(\'button\');\n            btnOpenMap.type = \'button\';\n            btnOpenMap.className = \'btn btn-outline-secondary\';\n            btnOpenMap.id = \'btn-open-map-picker\';\n            btnOpenMap.title = \'在地图上选点定位\';\n            btnOpenMap.innerHTML = \'<i class="mdi mdi-map-marker-radius"></i>\';\n            btnOpenMap.style.cssText = \'padding: 0.375rem 0.5rem; line-height: 1; font-size: 1.1rem;\';\n            inputGroup.appendChild(btnOpenMap);\n        } else {\n            const wrapper = document.createElement(\'div\');\n            wrapper.className = \'input-group\';\n            longitudeInput.parentNode.insertBefore(wrapper, longitudeInput);\n            wrapper.appendChild(longitudeInput);\n            \n            btnOpenMap = document.createElement(\'button\');\n            btnOpenMap.type = \'button\';\n            btnOpenMap.className = \'btn btn-outline-secondary\';\n            btnOpenMap.id = \'btn-open-map-picker\';\n            btnOpenMap.title = \'在地图上选点定位\';\n            btnOpenMap.innerHTML = \'<i class="mdi mdi-map-marker-radius"></i>\';\n            btnOpenMap.style.cssText = \'padding: 0.375rem 0.5rem; line-height: 1; font-size: 1.1rem;\';\n            wrapper.appendChild(btnOpenMap);\n        }\n        \n        // 创建模态窗口 (纯 DOM 控制，不依赖 bootstrap.Modal API)\n        const modalHtml = `\n        <div class="modal fade" id="mapPickerModal" tabindex="-1" aria-labelledby="mapPickerModalLabel" aria-hidden="true">\n            <div class="modal-dialog modal-xl modal-dialog-centered">\n                <div class="modal-content">\n                    <div class="modal-header py-2">\n                        <h5 class="modal-title" id="mapPickerModalLabel">\n                            <i class="mdi mdi-map-marker-radius me-1"></i>地图选点定位\n                        </h5>\n                        <button type="button" class="btn-close" id="mapPickerCloseBtn" aria-label="Close"></button>\n                    </div>\n                    <div class="modal-body p-0">\n                        <iframe id="mapPickerIframe" style="width: 100%; height: 70vh; border: none;"></iframe>\n                    </div>\n                </div>\n            </div>\n        </div>`;\n        document.body.insertAdjacentHTML(\'beforeend\', modalHtml);\n        \n        const modalEl = document.getElementById(\'mapPickerModal\');\n        const iframe = document.getElementById(\'mapPickerIframe\');\n        const closeBtn = document.getElementById(\'mapPickerCloseBtn\');\n        let backdrop = null;\n        \n        // 手动显示模态窗口\n        function showModal(url) {\n            iframe.src = url;\n            // 创建背景遮罩\n            backdrop = document.createElement(\'div\');\n            backdrop.className = \'modal-backdrop fade show\';\n            backdrop.style.opacity = \'0.85\';\n            document.body.appendChild(backdrop);\n            // 显示模态\n            modalEl.style.display = \'block\';\n            modalEl.classList.add(\'show\');\n            modalEl.setAttribute(\'aria-hidden\', \'false\');\n            document.body.classList.add(\'modal-open\');\n        }\n        \n        // 手动隐藏模态窗口\n        function hideModal() {\n            modalEl.classList.remove(\'show\');\n            modalEl.style.display = \'none\';\n            modalEl.setAttribute(\'aria-hidden\', \'true\');\n            document.body.classList.remove(\'modal-open\');\n            if (backdrop) {\n                backdrop.remove();\n                backdrop = null;\n            }\n            iframe.src = \'about:blank\';\n        }\n        \n        // 关闭按钮\n        closeBtn.addEventListener(\'click\', hideModal);\n        // 点击遮罩关闭\n        modalEl.addEventListener(\'click\', function(e) {\n            if (e.target === modalEl) hideModal();\n        });\n        \n        btnOpenMap.addEventListener(\'click\', function() {\n            // 获取下拉框中选择的 A 端站点和 Z 端站点\n            const aSiteSelect = document.querySelector(\'select[name="interruption_location_a"]\');\n            const zSiteSelect = document.querySelector(\'select[name="interruption_location"]\');\n            \n            const aSiteId = aSiteSelect ? aSiteSelect.value : \'\';\n            let zSites = [];\n            \n            if (zSiteSelect && zSiteSelect.options) {\n                for (let i = 0; i < zSiteSelect.options.length; i++) {\n                    if (zSiteSelect.options[i].selected && zSiteSelect.options[i].value) {\n                        zSites.push(zSiteSelect.options[i].value);\n                    }\n                }\n            }\n            \n            let url = \'/plugins/otnfaults/map/location/?picker=true\';\n            if (aSiteId) url += \'&a_site=\' + encodeURIComponent(aSiteId);\n            if (zSites.length > 0) url += \'&z_sites=\' + encodeURIComponent(zSites.join(\',\'));\n            \n            // 获取当前经纬度作为初始定位（如果有）\n            const currentLat = document.getElementById(\'id_interruption_latitude\').value;\n            const currentLng = document.getElementById(\'id_interruption_longitude\').value;\n            if (currentLat && currentLng) {\n                url += \'&q=\' + currentLat + \',\' + currentLng;\n            }\n            \n            showModal(url);\n        });\n        \n        // 监听来自 iframe 地图窗口的消息\n        window.addEventListener(\'message\', function(event) {\n            if (event.data && event.data.type === \'OTN_LOCATION_PICKED\') {\n                document.getElementById(\'id_interruption_latitude\').value = event.data.lat;\n                document.getElementById(\'id_interruption_longitude\').value = event.data.lng;\n                hideModal();\n            }\n            if (event.data && event.data.type === \'OTN_LOCATION_CANCEL\') {\n                hideModal();\n            }\n        });\n    }\n\n    function initFiberLogic() {\n        const resourceTypeSelect = document.querySelector(\'select[name="resource_type"]\');\n        const maintenanceModeSelect = document.querySelector(\'select[name="maintenance_mode"]\');\n        \n        if (!resourceTypeSelect || !maintenanceModeSelect) return;\n        \n        const resourceTypeTS = resourceTypeSelect.tomselect;\n        const maintenanceModeTS = maintenanceModeSelect.tomselect;\n        \n        if (!resourceTypeTS || !maintenanceModeTS) {\n            setTimeout(initFiberLogic, 100);\n            return;\n        }\n        \n        resourceTypeTS.on(\'change\', function(value) {\n            if (isCascadeUpdating) return;\n            isCascadeUpdating = true;\n            if (value === \'leased\') {\n                maintenanceModeTS.setValue(\'leased_owned\');\n            } else if (value === \'coordinated\') {\n                maintenanceModeTS.setValue(\'coordinated\');\n            }\n            setTimeout(() => { isCascadeUpdating = false; }, 10);\n        });\n    }\n\n    function initManagerLogic() {\n        const provinceSelect = document.querySelector(\'select[name="province"]\');\n        const lineManagerSelect = document.querySelector(\'select[name="line_manager"]\');\n        \n        if (!provinceSelect || !lineManagerSelect) return;\n        \n        const provinceTS = provinceSelect.tomselect;\n        const lineManagerTS = lineManagerSelect.tomselect;\n        \n        if (!provinceTS || !lineManagerTS) {\n            setTimeout(initManagerLogic, 100);\n            return;\n        }\n\n        // 线路主管分工地图 (Key 为省份简称或关键字，Value 为主管姓名)\n        const MANAGER_MAP = {\n            \'甘肃\': \'冯鑫源\', \'宁夏\': \'冯鑫源\', \'青海\': \'冯鑫源\', \'新疆\': \'冯鑫源\', \'山东\': \'冯鑫源\', \'陕西\': \'冯鑫源\', \'内蒙古\': \'冯鑫源\', \'浙江\': \'冯鑫源\', \'四川\': \'冯鑫源\', \'江西\': \'冯鑫源\',\n            \'广东\': \'姜川\', \'湖南\': \'姜川\', \'福建\': \'姜川\', \'重庆\': \'姜川\', \'贵州\': \'姜川\', \'云南\': \'姜川\', \'海南\': \'姜川\',\n            \'北京\': \'李立彬\', \'天津\': \'李立彬\', \'河北\': \'李立彬\', \'河南\': \'李立彬\', \'山西\': \'李立彬\', \'广西\': \'李立彬\',\n            \'湖北\': \'孙振伟\', \'安徽\': \'孙振伟\', \'江苏\': \'孙振伟\', \'上海\': \'孙振伟\',\n            \'黑龙江\': \'李小涛\', \'吉林\': \'李小涛\', \'辽宁\': \'李小涛\'\n        };\n\n        provinceTS.on(\'change\', function(value) {\n            if (!value) return;\n            \n            // 安全获取选中省份的显示文本 (兼容 Netbox AJAX 传入项和静态项)\n            let provinceText = \'\';\n            const opt = provinceTS.options[value];\n            if (opt) {\n                provinceText = opt.display || opt.name || opt.text || opt.label || \'\';\n            }\n            // 后备方案：从 DOM 节点直接获取\n            if (!provinceText) {\n                const itemNode = provinceTS.getItem(value);\n                if (itemNode) {\n                    provinceText = itemNode.textContent || itemNode.innerText || \'\';\n                }\n            }\n            // 最后的后备方案：原生 select\n            if (!provinceText && provinceSelect.selectedIndex >= 0) {\n                const selectedOption = provinceSelect.options[provinceSelect.selectedIndex];\n                if (selectedOption) provinceText = selectedOption.text || \'\';\n            }\n            \n            provinceText = provinceText.trim();\n            console.log(\'[ManagerLogic] 省份变更: "\' + provinceText + \'", Value:\', value);\n            if (!provinceText) return;\n\n            // 匹配分工\n            let managerName = null;\n            for (const key in MANAGER_MAP) {\n                if (provinceText.includes(key)) {\n                    managerName = MANAGER_MAP[key];\n                    break;\n                }\n            }\n\n            if (managerName) {\n                console.log(\'[ManagerLogic] 匹配到主管分工:\', managerName);\n                \n                // 执行查找主管的 API 请求\n                const searchAndSetUser = (queryUrl) => {\n                    fetch(queryUrl, {\n                        headers: {\n                            \'Accept\': \'application/json\',\n                            \'X-Requested-With\': \'XMLHttpRequest\'\n                        },\n                        credentials: \'same-origin\'\n                    })\n                    .then(res => {\n                        if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);\n                        return res.json();\n                    })\n                    .then(data => {\n                        let targetUser = null;\n                        if (data.results && data.results.length > 0) {\n                            // 在结果中查找匹配的姓名 (匹配 display, username, last_name+first_name 等)\n                            targetUser = data.results.find(u => \n                                (u.display && u.display.includes(managerName)) || \n                                (u.username && u.username.includes(managerName))\n                            ) || data.results[0]; // 退化选择第一个\n                        }\n                        \n                        if (targetUser) {\n                            console.log(\'[ManagerLogic] API 查找到主管:\', targetUser.display || targetUser.username, \'ID:\', targetUser.id);\n                            // TomSelect 兼容性处理：添加选项时提供尽可能多的字段标签，并确保 value 是字符串型（避免全等比较失败）\n                            const userIdStr = targetUser.id.toString();\n                            const userName = targetUser.display || targetUser.username;\n                            \n                            lineManagerTS.addOption({\n                                value: userIdStr,\n                                id: userIdStr,\n                                text: userName,\n                                label: userName,\n                                name: userName,\n                                display: userName\n                            });\n                            \n                            // 优先触发选择并同步数据\n                            lineManagerTS.setValue(userIdStr);\n                            lineManagerTS.addItem(userIdStr);\n                        } else if (queryUrl.includes(\'?q=\')) {\n                            // 如果带 q 查不到，尝试进行全量（限100）遍历查找（应对姓、名拆分情况）\n                            console.warn(\'[ManagerLogic] q 搜索失败，尝试全量查找...\');\n                            searchAndSetUser(\'/api/users/users/?limit=100\');\n                        } else {\n                            console.warn(\'[ManagerLogic] 未在系统中找到名为\', managerName, \'的用户\');\n                        }\n                    })\n                    .catch(e => console.error(\'[ManagerLogic] 自动匹配主管