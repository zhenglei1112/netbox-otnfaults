annedTimeModal" tabindex="-1" aria-labelledby="generatePlannedTimeModalLabel" aria-hidden="true" style="display: none;">\n  <div class="modal-dialog modal-dialog-centered generate-planned-time-dialog">\n    <div class="modal-content">\n      <div class="modal-header">\n        <h5 class="modal-title" id="generatePlannedTimeModalLabel">生成新的割接时间</h5>\n        <button type="button" class="btn-close" onclick="hideGeneratePlannedTimeModal()" aria-label="Close"></button>\n      </div>\n      <div class="modal-body">\n        <div class="mb-3">\n          <label class="form-label fw-semibold mb-2" for="id_planned_cutover_time_modal">请选择新的计划时间</label>\n          <input type="datetime-local" name="planned_cutover_time_modal" id="id_planned_cutover_time_modal" class="form-control form-control-sm" style="max-width: 250px;" value="{% if object.planned_cutover_time %}{{ object.planned_cutover_time|date:\'Y-m-d\\T00:00\' }}{% endif %}" required>\n        </div>\n        <div class="alert alert-warning mb-0 py-2 px-3" style="font-size: 0.925rem; border-left: 4px solid #ff9800;">\n          <i class="mdi mdi-alert-circle-outline me-2 text-warning" style="font-size: 1.1rem; vertical-align: middle;"></i>\n          <span id="generatePlannedTimeStatus" class="align-middle">生成新的割接时间，需要重新与每个影响业务确认，会重置所有影响业务的协调状态，确定生成吗？</span>\n        </div>\n      </div>\n      <div class="modal-footer">\n        <button type="button" class="btn btn-primary generate-planned-time-btn" id="generatePlannedTimeConfirmBtn" onclick="submitGeneratePlannedTimeForm()">\n          确认生成\n        </button>\n        <button type="button" class="btn btn-secondary generate-planned-time-btn" id="generatePlannedTimeCloseBtn" onclick="hideGeneratePlannedTimeModal()">\n          取消\n        </button>\n      </div>\n    </div>\n  </div>\n</div>\n<div class="modal-backdrop fade show" id="generatePlannedTimeBackdrop" style="display: none;"></div>\n\n\n<div class="field-group my-5">\n  <div class="row mb-3"><h2 class="col-9 