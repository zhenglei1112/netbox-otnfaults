 \'id_rectification_measures\',\n            \'id_rectification_description\',\n            \'id_rectification_subject\',\n            \'id_rectification_progress\',\n            \'id_planned_completion_time\',\n            \'id_actual_completion_time\',\n            \'id_rectification_completion_description\',\n            \'id_re_cutover\'\n        ];\n        \n        const fieldRows = [];\n        fieldIds.forEach(id => {\n            const input = document.getElementById(id);\n            if (input) {\n                const row = input.closest(\'.row\');\n                if (row) {\n                    fieldRows.push(row);\n                }\n            }\n        });\n        \n        function toggleFields() {\n            const displayStyle = (statusSelect.value === \'required\') ? \'flex\' : \'none\';\n            fieldRows.forEach(row => {\n                row.style.display = displayStyle;\n            });\n        }\n        \n        // 监听原生 change 事件\n        statusSelect.addEventListener(\'change\', toggleFields);\n        \n        // 监听 TomSelect change 事件（如果存在）\n        const ts = statusSelect.tomselect;\n        if (ts) {\n            ts.on(\'change\', toggleFields);\n        } else {\n            let checkCount = 0;\n            const checkTS = setInterval(() => {\n                checkCount++;\n                if (statusSelect.tomselect) {\n                    statusSelect.tomselect.on(\'change\', toggleFields);\n                    clearInterval(checkTS);\n                }\n                if (checkCount > 20) {\n                    clearInterval(checkTS);\n                }\n            }, 100);\n        }\n        \n        // 初始化时执行一次判定\n        toggleFields();\n    }\n\n    if (document.readyState === \'complete\') {\n        setTimeout(initMapPicker, 200);\n        setTimeout(initPathShortcuts, 200);\n        setTimeout(initPlannedTimes, 200);\n        setTimeout(initManagementUnitAutoFill, 200);\n        setTimeout(initManagerLogic, 200